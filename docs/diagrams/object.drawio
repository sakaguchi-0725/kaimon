                </mxCell>
                <mxCell id="c3-note" value="サインアップ直後の状態。&lt;div&gt;アカウント と 家族メンバー / 招待 の関係は 0..*&lt;/div&gt;&lt;div&gt;（未所属もあり得る）。&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=13;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
                    <mxGeometry x="300" y="1220" width="360" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="tpl-label" value="テンプレート（参考）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=2;fontSize=11;fontColor=#999999;" vertex="1" parent="1">
