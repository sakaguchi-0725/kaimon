                <mxCell id="c3-title" value="ケース3: スズキ花子（単独ユーザー・家族未所属）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
