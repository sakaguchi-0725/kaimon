{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "generate:api": "openapi-typescript ../docs/api/openapi.yml -o src/shared/api/schema.d.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@vee-validate/zod": "^4.15.1",
    "openapi-fetch": "^0.17.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@storybook/vue3": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.9.0",
    "jiti": "^2.6.1",
    "msw": "^2.13.2",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.2",
    "storybook": "^10.3.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
}
